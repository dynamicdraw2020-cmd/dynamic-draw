# Supabase 프로젝트 > Project Settings > API에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
# 구버전 키 이름을 쓰려면 위 줄 대신 아래 이름도 가능합니다.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 절대 브라우저에 노출하면 안 됩니다. Vercel 환경변수에만 넣으세요.
SUPABASE_SECRET_KEY=YOUR_SECRET_OR_SERVICE_ROLE_KEY
# 구버전 키 이름을 쓰려면 위 줄 대신 아래 이름도 가능합니다.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 실제 주소. 배포 전에는 http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 운영 사이트에서는 false
NEXT_PUBLIC_DEMO_MODE=false

# 최초 최고 관리자 생성 페이지(/setup-admin)에서 한 번만 사용하는 32자 이상의 비밀문자
ADMIN_SETUP_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32_CHARS_OR_MORE
