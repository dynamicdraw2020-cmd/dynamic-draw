# Supabase 프로젝트 > Project Settings > API Keys에서 복사
# URL은 /rest/v1 없이 https://프로젝트ID.supabase.co 만 넣으세요.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# 브라우저 공개용 키입니다. 반드시 sb_publishable_... 또는 legacy anon JWT만 넣으세요.
# 절대 sb_secret_... / service_role 키를 넣으면 안 됩니다.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLIC_KEY
# 구버전 키 이름을 쓰려면 위 줄 대신 아래 이름도 가능합니다.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LEGACY_ANON_KEY

# 서버 전용 키입니다. 반드시 sb_secret_... 또는 legacy service_role JWT만 넣으세요.
# Vercel 환경변수에만 넣고, NEXT_PUBLIC_ 이름으로 만들지 마세요.
SUPABASE_SECRET_KEY=sb_secret_YOUR_SERVER_SECRET_KEY
# 구버전 키 이름을 쓰려면 위 줄 대신 아래 이름도 가능합니다.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_LEGACY_SERVICE_ROLE_KEY

# 실제 주소. 배포 전에는 http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 운영 사이트에서는 false
NEXT_PUBLIC_DEMO_MODE=false

# 최초 최고 관리자 생성 페이지(/setup-admin)에서 한 번만 사용하는 32자 이상의 비밀문자
ADMIN_SETUP_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_32_CHARS_OR_MORE
